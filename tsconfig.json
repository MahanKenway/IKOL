{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/index.ts",
    "src/types/**/*.ts",
    "src/config/**/*.ts",
    "src/bot/**/*.ts",
    "src/services/logger/**/*.ts",
    "src/services/cache/**/*.ts",
    "src/services/database/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/modules/**/*",
    "src/services/api/**/*",
    "src/services/providers/**/*",
    "src/utils/**/*"
  ]
}
