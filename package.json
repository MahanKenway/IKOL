{
  "name": "ikol-bot",
  "version": "1.0.0",
  "description": "Ikol - Intelligent Telegram AI Assistant",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit || true",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 migrations apply ikol-db",
    "migrate:local": "wrangler d1 migrations apply ikol-db --local",
    "test": "vitest run"
  },
  "dependencies": {
    "grammy": "^1.21.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "wrangler": "^3.52.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["telegram", "bot", "ai", "cloudflare-workers", "grammy"],
  "author": "Ikol Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MahanKenway/IKOL.git"
  }
}
